{
  "name": "aspnet-buildtools",
  "version": "0.3.1",
  "description": "Utilities for integrating modern build tools in ASP.NET projects",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Baune8D/aspnet-buildtools.git"
  },
  "author": "Baune8D",
  "homepage": "https://github.com/Baune8D/aspnet-buildtools",
  "bugs": "https://github.com/Baune8D/aspnet-buildtools/issues",
  "main": "dist/index.js",
  "type": "module",
  "files": [
    "dist/**/**",
    "!**/*.tsbuildinfo",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "glob": "^13.0.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@jest/globals": "^30.3.0",
    "@types/node": "^24.12.0",
    "@types/webpack": "^5.28.5",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "ts-node": "^10.9.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1"
  },
  "scripts": {
    "format": "prettier --write . && eslint --fix .",
    "lint": "eslint \"**/*.{ts,mjs}\" --max-warnings=0 --report-unused-disable-directives",
    "test": "NODE_NO_WARNINGS=1 node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "build": "rm -rf dist && tsc --project tsconfig.build.json",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">= 22"
  }
}
